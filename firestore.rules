rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // SiteContent Entity
    match /siteConfig/{documentId} {
      // Anyone can read the config. Only the custom backend can write.
      allow read: if true;
      allow write: if false; 
    }

    // Applications Entity
    match /applications/{documentId} {
      allow create: if true;
      // Normal clients cannot read or modify applications. Only the custom backend can.
      allow read, update, delete: if false;
    }
  }
}

